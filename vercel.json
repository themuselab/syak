{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "VITE_TARGET=vercel vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/nail/:gu", "destination": "/api/nail?gu=:gu" },
    { "source": "/nail/:gu/", "destination": "/api/nail?gu=:gu" },
    { "source": "/((?!assets|data|api|icon|favicon|robots|sitemap|nail|og|fallback).*)", "destination": "/" }
  ]
}
